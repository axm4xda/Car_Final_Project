@model Car_Project.ViewModels.Home.HomeIndexViewModel
@using Car_Project.ViewModels.Home

<!-- page-title -->
<form asp-controller="List" asp-action="Index" method="get">
	<section class="page-title flex h-706">
		<div class="swiper-container page-title--slider sw-single">
			<div class="swiper-wrapper">
				<div class="swiper-slide">
					<div class="tp-showcase-slider-bg" data-background="/assets/images/page-title/banner-1.jpg"></div>
				</div>
				<div class="swiper-slide">
					<div class="tp-showcase-slider-bg" data-background="/assets/images/page-title/banner-2.jpg"></div>
				</div>
				<div class="swiper-slide">
					<div class="tp-showcase-slider-bg" data-background="/assets/images/page-title/banner-3.jpg"></div>
				</div>
				<div class="swiper-slide">
					<div class="tp-showcase-slider-bg" data-background="/assets/images/page-title/banner-5.jpg"></div>
				</div>
			</div>
		</div>

		<!-- Search Cars Section -->
		<div class="search-cars container margin-top-auto margin-bottom-auto">
			<h1 class="search-cars__title wow fadeInUp" data-wow-delay="0.1s">Search Cars Near You - Buy Today!</h1>

			<div class="flat-tabs mb-16 wow fadeInUp" data-wow-delay="0.3s">
				<div class="overflow-x-auto">
					<ul class="menu-tab menu-tab-style1 text-white">
						<li class="active"><span class="text-white font-weight-600">All Car</span></li>
						<li><span class="text-white font-weight-600">New Car</span></li>
					</ul>
				</div>
			</div>

			<!-- Primary Search Filters -->
			<div class="search-cars__filters wow fadeInUp" data-wow-delay="0.5s">
				<div class="search-cars__select-wrapper">
					<div class="search-cars__select bg-white filter-select-dropdown" data-name="Brand">
						<label for="BrandSelectToggle" class="search-cars__label">Select Brand</label>
						<input type="checkbox" id="BrandSelectToggle" class="filter-select-dropdown__toggle">
						<label for="BrandSelectToggle" class="filter-select-dropdown__text">
							<span>All Brand</span>
						</label>
						<div class="filter-select-dropdown__menu">
							<div class="filter-select-dropdown__list">
								<label class="filter-checkbox">
									<input type="checkbox" name="Brand" value="all" checked>
									<span>All Brand</span>
								</label>
								@foreach (var brand in Model.BrandNames)
								{
									<label class="filter-checkbox">
										<input type="checkbox" name="Brand" value="@brand">
										<span>@brand</span>
									</label>
								}
							</div>
						</div>
					</div>
				</div>

				<div class="search-cars__select-wrapper">
					<div class="search-cars__select bg-white filter-select-dropdown" data-name="FuelType">
						<label for="FuelTypeSelectToggle" class="search-cars__label">Fuel Type</label>
						<input type="checkbox" id="FuelTypeSelectToggle" class="filter-select-dropdown__toggle">
						<label for="FuelTypeSelectToggle" class="filter-select-dropdown__text">
							<span>All Fuel</span>
						</label>
						<div class="filter-select-dropdown__menu">
							<div class="filter-select-dropdown__list">
								<label class="filter-checkbox">
									<input type="checkbox" name="FuelType" value="all" checked>
									<span>All Fuel</span>
								</label>
								@foreach (var fuel in Model.FuelTypes)
								{
									<label class="filter-checkbox">
										<input type="checkbox" name="FuelType" value="@fuel">
										<span>@fuel</span>
									</label>
								}
							</div>
						</div>
					</div>
				</div>

				<div class="search-cars__select-wrapper">
					<div class="search-cars__select bg-white filter-select-dropdown" data-name="Transmission">
						<label for="TransmissionSelectToggle" class="search-cars__label">Transmission</label>
						<input type="checkbox" id="TransmissionSelectToggle" class="filter-select-dropdown__toggle">
						<label for="TransmissionSelectToggle" class="filter-select-dropdown__text">
							<span>All</span>
						</label>
						<div class="filter-select-dropdown__menu">
							<div class="filter-select-dropdown__list">
								<label class="filter-checkbox">
									<input type="checkbox" name="Transmission" value="all" checked>
									<span>All</span>
								</label>
								@foreach (var t in Model.Transmissions)
								{
									<label class="filter-checkbox">
										<input type="checkbox" name="Transmission" value="@t">
										<span>@t</span>
									</label>
								}
							</div>
						</div>
					</div>
				</div>

				<!-- Filter Icon Button -->
				<div class="search-cars__filter" id="filterToggle">
					<img src="~/assets/icons/filter.svg" alt="Filter">
				</div>

				<button type="submit" class="search-cars__search flex items-center gap-8 justify-center md-w-full">
					<img src="~/assets/icons/search.svg" alt="search">
					Show @Model.TotalMatchCount.ToString("N0") Matches
				</button>
			</div>
		</div>
		<!-- Search Cars Section -->

		<div class="swiper-pagination pagination-white pagination-style pagination-page-title--slider-1 mt-38"></div>
	</section>
</form>
<!-- page-title -->

<!-- New Cars -->
<section class="container py-100 flat-tabs">
	<div class="title-section mb-30 gap-8 wow fadeInUp" data-wow-delay="0.1s">
		<ul class="menu-tab menu-tab-style2 text-white gap-40 md-gap-12">
			<li class="active"><h2 class="text">New Cars</h2></li>
		</ul>
		<a asp-controller="List" asp-action="Index" class="btn btn-line-style-2 effect-line-primary hover-fill-white effect-line-primary btn-large">
			View All
			<svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M8.125 0C6.51803 0 4.94714 0.476523 3.611 1.36931C2.27485 2.2621 1.23344 3.53105 0.618482 5.0157C0.00352044 6.50035 -0.157382 8.13401 0.156123 9.71011C0.469628 11.2862 1.24346 12.7339 2.37976 13.8702C3.51606 15.0065 4.9638 15.7804 6.5399 16.0939C8.11599 16.4074 9.74966 16.2465 11.2343 15.6315C12.719 15.0166 13.9879 13.9752 14.8807 12.639C15.7735 11.3029 16.25 9.73197 16.25 8.125C16.2477 5.97081 15.391 3.90551 13.8677 2.38227C12.3445 0.85903 10.2792 0.00227486 8.125 0ZM11.6922 8.56719L9.19219 11.0672C9.07492 11.1845 8.91586 11.2503 8.75 11.2503C8.58415 11.2503 8.42509 11.1845 8.30782 11.0672C8.19054 10.9499 8.12466 10.7909 8.12466 10.625C8.12466 10.4591 8.19054 10.3001 8.30782 10.1828L9.74141 8.75H5C4.83424 8.75 4.67527 8.68415 4.55806 8.56694C4.44085 8.44973 4.375 8.29076 4.375 8.125C4.375 7.95924 4.44085 7.80027 4.55806 7.68306C4.67527 7.56585 4.83424 7.5 5 7.5H9.74141L8.30782 6.06719C8.19054 5.94991 8.12466 5.79085 8.12466 5.625C8.12466 5.45915 8.19054 5.30009 8.30782 5.18281C8.42509 5.06554 8.58415 4.99965 8.75 4.99965C8.91586 4.99965 9.07492 5.06554 9.19219 5.18281L11.6922 7.68281C11.7503 7.74086 11.7964 7.80979 11.8279 7.88566C11.8593 7.96154 11.8755 8.04287 11.8755 8.125C11.8755 8.20713 11.8593 8.28846 11.8279 8.36434C11.7964 8.44021 11.7503 8.50914 11.6922 8.56719Z" fill="#1C1C1C" />
			</svg>
		</a>
	</div>
	<div class="content-tab">
		<div class="content-inner active">
			<div class="swiper-container swiper-card-7" data-pagination=".pagination-swiper-card-7-1">
				<div class="swiper-wrapper">
					@for (int i = 0; i < Model.NewCars.Count; i++)
					{
						var car = Model.NewCars[i];
						var delays = new[] { "0.1s", "0.2s", "0.3s", "0.4s" };
						var delay = delays[i % delays.Length];
						<div class="swiper-slide">
							<div class="card-box card-box-style-1 mt-10 wow fadeIn" data-wow-delay="@delay">
								<div class="top">
									@if (!string.IsNullOrEmpty(car.Badge))
									{
										<p class="@car.BadgeColor text-white highlight">@car.Badge</p>
									}
									else
									{
										<p></p>
									}
									<p class="heart">
										<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
											<g clip-path="url(#clip0_13399_19510)">
												<path d="M8 14C8 14 1.5 10.5 1.5 6.375C1.5 5.47989 1.85558 4.62145 2.48851 3.98851C3.12145 3.35558 3.97989 3 4.875 3C6.28688 3 7.49625 3.76937 8 5C8.50375 3.76937 9.71312 3 11.125 3C12.0201 3 12.8785 3.35558 13.5115 3.98851C14.1444 4.62145 14.5 5.47989 14.5 6.375C14.5 10.5 8 14 8 14Z" stroke="white" stroke-linecap="round" stroke-linejoin="round" />
											</g>
										</svg>
									</p>
								</div>
								<div class="image">
									<a asp-controller="List" asp-action="Detail" asp-route-id="@car.Id">
										<img class="card--img" src="@car.ThumbnailUrl" alt="@car.Title">
									</a>
								</div>
								<div class="content border-light border-top-none">
									<div class="bottom">
										<p class="category uppercase text-white">
											<a asp-controller="List" asp-action="Index" asp-route-brand="@car.BrandName" class="text-white uppercase text-xs">@car.BrandName</a>
										</p>
										<div class="flex items-center gap-8">
											<p class="category uppercase text-white">
												<img src="~/assets/icons/picture.svg" alt="picture">
												@car.ImageCount
											</p>
											<p class="category uppercase text-white">
												<img src="~/assets/icons/play.svg" alt="play">
												@car.VideoCount
											</p>
										</div>
									</div>
									<p class="card-box__title mb-8 h6">
										<a asp-controller="List" asp-action="Detail" asp-route-id="@car.Id">@car.Title</a>
									</p>
									<ul class="tag mb-10">
										<li>
											<img src="~/assets/icons/icon-gauge.svg" alt="mileage">
											<span>@car.Mileage.ToString("N0") miles</span>
										</li>
										<li>
											<img src="~/assets/icons/calendar.svg" alt="year">
											<span>@car.Year</span>
										</li>
										<li>
											<img src="~/assets/icons/gaspump.svg" alt="fuel">
											<span>@car.FuelType</span>
										</li>
										<li>
											<img src="~/assets/icons/manual.svg" alt="transmission">
											<span>@car.Transmission</span>
										</li>
									</ul>
									@if (car.MonthlyPayment.HasValue)
									{
										<p class="h6 card-box__price mb-15 flex justify-between gap-8 items-center">
											$@car.Price.ToString("N2")
											<span class="text-sm">
												$@car.MonthlyPayment.Value.ToString("N0")/mo
												<a asp-controller="List" asp-action="Detail" asp-route-id="@car.Id" class="text-underline ml-2 text-muted text-xs">See Finance</a>
											</span>
										</p>
									}
									else
									{
										<p class="card-box__price mb-15">$@car.Price.ToString("N2")</p>
									}
									<div class="divider mb-15"></div>
									<div class="flex justify-between">
										<p class="compare-details btn btn-small open-modal" data-modal-id="#CompareModal">
											<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
												<g clip-path="url(#clip0_13399_19575)">
													<path d="M10 17.5C14.1421 17.5 17.5 14.1421 17.5 10C17.5 5.85786 14.1421 2.5 10 2.5C5.85786 2.5 2.5 5.85786 2.5 10C2.5 14.1421 5.85786 17.5 10 17.5Z" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
													<path d="M6.875 10H13.125" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
													<path d="M10 6.875V13.125" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
												</g>
											</svg>
											Compare
										</p>
										<a asp-controller="List" asp-action="Detail" asp-route-id="@car.Id" class="view-details">
											View details
											<img class="ml-4" src="~/assets/icons/CaretCircleRight.svg" alt="CaretCircleRight.svg">
										</a>
									</div>
								</div>
							</div>
						</div>
					}
				</div>
				<div class="swiper-pagination pagination-dark pagination-style pagination-swiper-card-7-1 mt-38"></div>
			</div>
		</div>
	</div>
</section>
<!-- New Cars -->

<!-- Browse By Type (static SVG iconlar saxlanıldı) -->
<section class="py-100 relative">
	<div class="overlay image">
		<img class="lazyload parallax" data-src="images/banner/cd-phonecase.jpg" src="~/assets/images/brand/banner-brand.png" alt="">
	</div>
	<div class="container wow fadeIn relative" data-wow-delay="0.2s">
		<div class="title-section mb-40">
			<h2 class="text-white text-center">Browse By Type</h2>
			<a asp-controller="List" asp-action="Index" class="btn btn-blur hover-fill-primary font-weight-600 btn-large">
