@model Car_Project.ViewModels.Blog.BlogIndexViewModel
@{
    ViewData["Title"] = "Blog";
}

<!-- breadcrumb -->
<section class="background-light mb-32">
    <div class="container">
        <ul class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><img src="~/assets/icons/right.svg" alt="chevron-right"></li>
            <li><span>News</span></li>
        </ul>
    </div>
</section>
<!-- breadcrumb -->

<!-- Blog Grid -->
<section class="pb-100">
    <div class="container">
        <h2>Blog</h2>
    </div>
    <div class="tf-spacing-style3"></div>

    <div class="container">

        @if (!Model.Posts.Any())
        {
            <div class="mb-40">
                <p class="text-secondary">Heç bir post tapılmadı.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-3 md-grid-cols-1 gap-y-40 gap-x-30 mb-40">
                @foreach (var post in Model.Posts)
                {
                    <a asp-controller="Blog" asp-action="Detail"
                       asp-route-slug="@post.Slug"
                       class="post-style-6 overflow-hidden">
                        <div class="image">
                            <img class="post--img flex"
                                 src="@(!string.IsNullOrEmpty(post.ThumbnailUrl) ? post.ThumbnailUrl : "/assets/images/blog/post-44.jpg")"
                                 alt="@post.Title">
                        </div>
                        <div class="content">
                            <div class="flex gap-12 justify-start mb-12">
                                <span class="text-sm">by @(post.AuthorName ?? "Admin")</span>
                                <span class="text-sm">@post.PublishedAt?.ToString("MMM dd, yyyy")</span>
                                <a asp-controller="Blog" asp-action="Index"
                                   asp-route-category="@post.CategoryName"
                                   class="text-sm text-highlight uppercase text-underline">@post.CategoryName</a>
                            </div>
                            <p class="h4 title mb-12">@post.Title</p>
                            <p class="clamp clamp-2 text-secondary">@post.Summary</p>
                        </div>
                    </a>
                }
            </div>
        }

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <ul class="pagination justify-center">
                @if (Model.CurrentPage > 1)
                {
                    <li>
                        <a asp-controller="Blog" asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-category="@Model.SelectedCategory"
                           asp-route-tag="@Model.SelectedTag"
                           asp-route-q="@Model.SearchQuery"
                           class="pagination__link">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M5.80762 10.4423L12.0576 16.6923C12.1157 16.7504 12.1846 16.7964 12.2605 16.8278C12.3364 16.8593 12.4177 16.8755 12.4998 16.8755C12.5819 16.8755 12.6632 16.8593 12.7391 16.8278C12.815 16.7964 12.8839 16.7504 12.942 16.6923C13.0001 16.6342 13.0461 16.5653 13.0776 16.4894C13.109 16.4135 13.1252 16.3322 13.1252 16.2501C13.1252 16.168 13.109 16.0867 13.0776 16.0108C13.0461 15.9349 13.0001 15.866 12.942 15.8079L7.13332 10.0001L12.942 4.19229C13.0593 4.07502 13.1252 3.91596 13.1252 3.7501C13.1252 3.58425 13.0593 3.42519 12.942 3.30792C12.8247 3.19064 12.6657 3.12476 12.4998 3.12476C12.3339 3.12476 12.1749 3.19064 12.0576 3.30792L5.80762 9.55791C5.74955 9.61596 5.70348 9.68489 5.67196 9.76077C5.64043 9.83664 5.62427 9.91797 5.62427 10.0001C5.62427 10.0822 5.64043 10.1636 5.67196 10.2394C5.70348 10.3153 5.74955 10.3842 5.80762 10.4423Z" fill="#9FA1A4" />
                            </svg>
                        </a>
                    </li>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li>
                        <a asp-controller="Blog" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-category="@Model.SelectedCategory"
                           asp-route-tag="@Model.SelectedTag"
                           asp-route-q="@Model.SearchQuery"
                           class="pagination__link @(i == Model.CurrentPage ? "active" : "")">
                            @i
                        </a>
                    </li>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li>
                        <a asp-controller="Blog" asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-category="@Model.SelectedCategory"
                           asp-route-tag="@Model.SelectedTag"
                           asp-route-q="@Model.SearchQuery"
                           class="pagination__link">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M14.1925 10.4423L7.94254 16.6923C7.88447 16.7504 7.81553 16.7964 7.73966 16.8278C7.66379 16.8593 7.58247 16.8755 7.50035 16.8755C7.41823 16.8755 7.33691 16.8593 7.26104 16.8278C7.18517 16.7964 7.11623 16.7504 7.05816 16.6923C7.00009 16.6342 6.95403 16.5653 6.9226 16.4894C6.89117 16.4135 6.875 16.3322 6.875 16.2501C6.875 16.168 6.89117 16.0867 6.9226 16.0108C6.95403 15.9349 7.00009 15.866 7.05816 15.8079L12.8668 10.0001L7.05816 4.19229C6.94088 4.07502 6.875 3.91596 6.875 3.7501C6.875 3.58425 6.94088 3.42519 7.05816 3.30792C7.17544 3.19064 7.3345 3.12476 7.50035 3.12476C7.6662 3.12476 7.82526 3.19064 7.94254 3.30792L14.1925 9.55791C14.2506 9.61596 14.2967 9.68489 14.3282 9.76077C14.3597 9.83664 14.3758 9.91797 14.3758 10.0001C14.3758 10.0822 14.3597 10.1636 14.3282 10.2394C14.2967 10.3153 14.2506 10.3842 14.1925 10.4423Z" fill="#9FA1A4" />
                            </svg>
                        </a>
                    </li>
                }
            </ul>
        }
    </div>
</section>
<!-- Blog Grid -->