@inject UserManager<AppUser> UserManager
@{
    var adminUser = await UserManager.GetUserAsync(User);
    var activePage = ViewData["ActivePage"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Admin Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{font-family:'Inter',sans-serif;background:#f0f2f5;color:#1c1c1c}
        a{text-decoration:none;color:inherit}

        /* ═══ Sidebar ═══ */
        .adm-side{position:fixed;top:0;left:0;bottom:0;width:260px;background:#1c1c2e;color:#fff;overflow-y:auto;z-index:100;display:flex;flex-direction:column}
        .adm-side::-webkit-scrollbar{width:4px}
        .adm-side::-webkit-scrollbar-thumb{background:#ffffff30;border-radius:4px}
        .adm-side-logo{padding:24px 20px;border-bottom:1px solid #ffffff15;display:flex;align-items:center;gap:12px}
        .adm-side-logo .ico{width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,#FF5722,#ff8a65);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:800;color:#fff}
        .adm-side-logo span{font-size:18px;font-weight:700}
        .adm-sec{padding:16px 0}
        .adm-sec-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:#ffffff50;padding:0 20px;margin-bottom:8px}
        .adm-link{display:flex;align-items:center;gap:12px;padding:10px 20px;font-size:13.5px;font-weight:500;color:#ffffffb0;transition:all .2s;border-left:3px solid transparent}
        .adm-link:hover{background:#ffffff10;color:#fff}
        .adm-link.active{background:#FF572220;color:#FF5722;border-left-color:#FF5722;font-weight:600}
        .adm-link svg{flex-shrink:0;width:20px;height:20px}

        /* ═══ Topbar ═══ */
        .adm-top{position:fixed;top:0;left:260px;right:0;height:64px;background:#fff;border-bottom:1px solid #e5e7eb;z-index:99;display:flex;align-items:center;justify-content:space-between;padding:0 28px}
        .adm-top h1{font-size:18px;font-weight:700}
        .adm-top-r{display:flex;align-items:center;gap:16px}
        .adm-top-user{display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600;color:#374151}
        .adm-top-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#FF5722,#ff8a65);color:#fff;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700}
        .adm-top-btn{padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;background:#f3f4f6;color:#374151;border:none;cursor:pointer;transition:all .2s}
        .adm-top-btn:hover{background:#e5e7eb}

        /* ═══ Content ═══ */
        .adm-content{margin-left:260px;margin-top:64px;padding:28px;min-height:calc(100vh - 64px)}

        /* ═══ Card ═══ */
        .a-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:24px;margin-bottom:24px}
        .a-card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px}
        .a-card-title{font-size:16px;font-weight:700}

        /* ═══ Stats ═══ */
        .stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;margin-bottom:28px}
        .st-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:20px;display:flex;align-items:center;gap:16px}
        .st-ico{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px}
        .st-ico.blue{background:#eff6ff;color:#2563eb}.st-ico.green{background:#ecfdf5;color:#059669}
        .st-ico.orange{background:#fff7ed;color:#ea580c}.st-ico.purple{background:#f5f3ff;color:#7c3aed}
        .st-ico.red{background:#fef2f2;color:#dc2626}.st-ico.teal{background:#f0fdfa;color:#0d9488}
        .st-val{font-size:24px;font-weight:800}
        .st-lbl{font-size:12px;color:#6b7280;font-weight:500;margin-top:2px}

        /* ═══ Table ═══ */
        .a-table{width:100%;border-collapse:collapse}
        .a-table thead th{text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#6b7280;padding:12px 14px;border-bottom:2px solid #e5e7eb;white-space:nowrap}
        .a-table tbody td{padding:12px 14px;border-bottom:1px solid #f3f4f6;font-size:13.5px;vertical-align:middle}
        .a-table tbody tr:hover{background:#f9fafb}
        .a-table .thumb{width:48px;height:48px;border-radius:8px;object-fit:cover}

        /* ═══ Buttons ═══ */
        .btn-a{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;border:none;cursor:pointer;transition:all .2s;text-decoration:none}
        .btn-a.primary{background:#FF5722;color:#fff}.btn-a.primary:hover{background:#e64a19}
        .btn-a.success{background:#ecfdf5;color:#059669}.btn-a.success:hover{background:#d1fae5}
        .btn-a.danger{background:#fef2f2;color:#dc2626}.btn-a.danger:hover{background:#fee2e2}
        .btn-a.info{background:#eff6ff;color:#2563eb}.btn-a.info:hover{background:#dbeafe}
        .btn-a.warning{background:#fff7ed;color:#ea580c}.btn-a.warning:hover{background:#fed7aa}
        .btn-a.ghost{background:#f3f4f6;color:#374151}.btn-a.ghost:hover{background:#e5e7eb}
        .btn-sm{padding:5px 10px;font-size:12px}

        /* ═══ Badge ═══ */
        .a-badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}
        .a-badge.green{background:#ecfdf5;color:#059669}.a-badge.red{background:#fef2f2;color:#dc2626}
        .a-badge.yellow{background:#fefce8;color:#ca8a04}.a-badge.blue{background:#eff6ff;color:#2563eb}
        .a-badge.gray{background:#f3f4f6;color:#6b7280}

        /* ═══ Forms ═══ */
        .fg{margin-bottom:18px}
        .fg label{display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px}
        .fc{width:100%;padding:10px 14px;border:1px solid #e5e7eb;border-radius:8px;font-size:14px;font-family:inherit;outline:none;transition:border-color .2s}
        .fc:focus{border-color:#FF5722}
        select.fc{appearance:auto}
        textarea.fc{resize:vertical;min-height:100px}
        .f-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
        .f-chk{display:flex;align-items:center;gap:8px;font-size:14px}
        .f-chk input[type="checkbox"]{width:18px;height:18px;accent-color:#FF5722}

        /* ═══ Alert ═══ */
        .a-alert{padding:14px 18px;border-radius:10px;margin-bottom:20px;font-size:14px;font-weight:500}
        .a-alert.success{background:#ecfdf5;color:#065f46;border:1px solid #a7f3d0}
        .a-alert.error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

        /* ═══ Misc ═══ */
        .empty-st{text-align:center;padding:60px 20px;color:#9ca3af}
        .empty-st p{font-size:15px;font-weight:500}
        .act-btns{display:flex;gap:6px}
        .del-form{display:inline}
        .tbl-wrap{overflow-x:auto}
    </style>
</head>
<body>
    <aside class="adm-side">
        <div class="adm-side-logo">
            <div class="ico">A</div>
            <span>Aurexo Admin</span>
        </div>

        <div class="adm-sec">
            <div class="adm-sec-title">Ana Menyu</div>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="adm-link @(activePage=="Dashboard"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                Dashboard
            </a>
        </div>

        <div class="adm-sec">
            <div class="adm-sec-title">Avtomobillər</div>
            <a asp-area="Admin" asp-controller="Car" asp-action="Index" class="adm-link @(activePage=="Cars"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 17h14M5 17a2 2 0 01-2-2V9a2 2 0 012-2h1l2-3h8l2 3h1a2 2 0 012 2v6a2 2 0 01-2 2M5 17a2 2 0 100 4 2 2 0 000-4zm14 0a2 2 0 100 4 2 2 0 000-4z"/></svg>
                Maşınlar
            </a>
            <a asp-area="Admin" asp-controller="Brand" asp-action="Index" class="adm-link @(activePage=="Brands"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a2.25 2.25 0 003.182 0l4.318-4.318a2.25 2.25 0 000-3.182L11.16 3.66A2.25 2.25 0 009.568 3z"/><path d="M6 6h.008v.008H6V6z"/></svg>
                Markalar
            </a>
            <a asp-area="Admin" asp-controller="CarFeature" asp-action="Index" class="adm-link @(activePage=="CarFeatures"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Xüsusiyyətlər
            </a>
        </div>

        <div class="adm-sec">
            <div class="adm-sec-title">Məzmun</div>
            <a asp-area="Admin" asp-controller="BlogPost" asp-action="Index" class="adm-link @(activePage=="BlogPosts"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2"/></svg>
                Blog Yazılar
            </a>
            <a asp-area="Admin" asp-controller="BlogCategory" asp-action="Index" class="adm-link @(activePage=="BlogCategories"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 7h.01M7 3h5l3.5 3.5L21 12a2 2 0 010 2.83l-5.17 5.17a2 2 0 01-2.83 0L3 10V5a2 2 0 012-2h2z"/></svg>
                Blog Kateqoriyalar
            </a>
            <a asp-area="Admin" asp-controller="Faq" asp-action="Index" class="adm-link @(activePage=="FAQs"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                FAQ
            </a>
        </div>

        <div class="adm-sec">
            <div class="adm-sec-title">Mağaza</div>
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="adm-link @(activePage=="Products"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Məhsullar
            </a>
            <a asp-area="Admin" asp-controller="ProductCategory" asp-action="Index" class="adm-link @(activePage=="ProductCategories"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16M4 12h16M4 18h7"/></svg>
                Məhsul Kateqoriyalar
            </a>
            <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="adm-link @(activePage=="Orders"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                Sifarişlər
            </a>
            <a asp-area="Admin" asp-controller="Coupon" asp-action="Index" class="adm-link @(activePage=="Coupons"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
                Kuponlar
            </a>
        </div>

        <div class="adm-sec">
            <div class="adm-sec-title">Agentlər & Rəylər</div>
            <a asp-area="Admin" asp-controller="SalesAgent" asp-action="Index" class="adm-link @(activePage=="SalesAgents"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                Satış Agentləri
            </a>
            <a asp-area="Admin" asp-controller="Review" asp-action="Index" class="adm-link @(activePage=="Reviews"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                Müştəri Rəyləri
            </a>
            <a asp-area="Admin" asp-controller="ServiceCenter" asp-action="Index" class="adm-link @(activePage=="ServiceCenters"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Servis Mərkəzləri
            </a>
        </div>

        <div class="adm-sec">
            <div class="adm-sec-title">Müraciətlər</div>
            <a asp-area="Admin" asp-controller="ContactMessage" asp-action="Index" class="adm-link @(activePage=="ContactMessages"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Əlaqə Mesajları
            </a>
            <a asp-area="Admin" asp-controller="SellCarRequest" asp-action="Index" class="adm-link @(activePage=="SellCarRequests"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Satış Müraciətləri
            </a>
            <a asp-area="Admin" asp-controller="Subscriber" asp-action="Index" class="adm-link @(activePage=="Subscribers"?"active":"")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                Abunəçilər
            </a>
        </div>

        <div class="adm-sec" style="margin-top:auto;border-top:1px solid #ffffff15;padding-top:16px;">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="adm-link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Sayta Qayıt
            </a>
        </div>
    </aside>

    <header class="adm-top">
        <h1>@ViewData["Title"]</h1>
        <div class="adm-top-r">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="adm-top-btn">🌐 Sayta Bax</a>
            <div class="adm-top-user">
                <div class="adm-top-avatar">@(adminUser?.FullName?.Substring(0,1) ?? "A")</div>
                <span>@(adminUser?.FullName ?? "Admin")</span>
            </div>
        </div>
    </header>

    <main class="adm-content">
        @if (TempData["Success"] != null)
        {
            <div class="a-alert success">✅ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="a-alert error">⚠️ @TempData["Error"]</div>
        }
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
