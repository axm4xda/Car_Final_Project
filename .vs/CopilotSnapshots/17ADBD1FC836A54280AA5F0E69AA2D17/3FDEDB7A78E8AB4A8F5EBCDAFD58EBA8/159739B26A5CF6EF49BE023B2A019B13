@model Car_Project.ViewModels.Blog.BlogDetailViewModel
@{
    var categories = ViewBag.Categories as IList<Car_Project.Models.BlogCategory> ?? new List<Car_Project.Models.BlogCategory>();
    var allTags = ViewBag.AllTags as IList<Car_Project.Models.BlogTag> ?? new List<Car_Project.Models.BlogTag>();
    var recentPosts = ViewBag.RecentPosts as IList<Car_Project.Models.BlogPost> ?? new List<Car_Project.Models.BlogPost>();
}

<section class="blog-details-banner">
	<img class="overlay-image" src="~/assets/images/blog/overlay-blogdetails.png" alt="blog-details-banner">
	<div class="breadcrumb-wrapper">
		<div class="container">
			<ul class="breadcrumb">
				<li>
					<a class="text-white" asp-controller="Home" asp-action="Index">Home</a>
				</li>
				<li>
					<img src="~/assets/icons/right.svg" alt="chevron-right">
				</li>
				<li>
					<a class="text-white" asp-controller="Blog" asp-action="Index">Blog</a>
				</li>
				<li>
					<img src="~/assets/icons/right.svg" alt="chevron-right">
				</li>
				<li>
					<span class="text-muted">@Model.Title</span>
				</li>
			</ul>
		</div>
	</div>
	<div class="image flex">
		@if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
		{
			<img src="@Model.ThumbnailUrl" alt="@Model.Title">
		}
		else
		{
			<img src="~/assets/images/blog/blog-details.jpg" alt="@Model.Title">
		}
	</div>

	<div class="content">
		<div class="container">
			<h1 class="mb-20 text-white letter-spacing-1">@Model.Title</h1>

			<ul class="flex items-center flex-wrap gap-20">
				<li><a class="text-white" href="#">by @(Model.AuthorName ?? "Admin")</a></li>
				<li><a class="text-white" href="#">@Model.PublishedAt?.ToString("MMM. d, yyyy")</a></li>
				<li><a class="uppercase text-underline text-highlight" asp-controller="Blog" asp-action="Index" asp-route-category="@Model.CategoryName">@Model.CategoryName</a></li>
			</ul>
		</div>
	</div>
</section>

<!-- Blog Content -->
<section>
	<div class="tf-spacing"></div>

	<div class="container innerpage-container">
		<div class="innerpage__content md-mb-30">

			@if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
			{
				<img class="post--img radius-20 flex mb-40" src="@Model.ThumbnailUrl" alt="@Model.Title">
			}

			<div class="mb-40">
				@Html.Raw(Model.Content)
			</div>

			<div class="flex justify-between mb-40 gap-16 md-flex-col">
				@if (Model.Tags.Any())
				{
					<ul class="blog-detail-tags flex gap-12">
						<li><p>Tag:</p></li>
						@foreach (var tag in Model.Tags)
						{
							<li>
								<a asp-controller="Blog" asp-action="Index" asp-route-tag="@tag">@tag</a>
							</li>
						}
					</ul>
				}

				<ul class="blog-detail-social flex gap-12">
					<li><p>Share this post:</p></li>
					<li>
						<a href="https://www.facebook.com/">
							<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
								<g clip-path="url(#clip0_13439_102340)">
									<path d="M6.25 11.25L8.75 8.75L11.25 11.25L13.75 8.75" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
									<path d="M6.24382 16.4932C7.81923 17.405 9.67248 17.7127 11.458 17.359C13.2436 17.0053 14.8396 16.0143 15.9484 14.5708C17.0573 13.1273 17.6033 11.3298 17.4847 9.51341C17.3662 7.69704 16.5911 5.98577 15.304 4.69866C14.0169 3.41156 12.3056 2.63646 10.4892 2.51789C8.67284 2.39932 6.87533 2.94537 5.43182 4.05422C3.98831 5.16308 2.99733 6.75906 2.64363 8.54461C2.28993 10.3302 2.59766 12.1834 3.50944 13.7588L2.5321 16.6768C2.49538 16.7869 2.49005 16.9051 2.51671 17.0181C2.54337 17.131 2.60097 17.2344 2.68306 17.3165C2.76514 17.3985 2.86847 17.4561 2.98145 17.4828C3.09443 17.5095 3.2126 17.5041 3.32273 17.4674L6.24382 16.4932Z" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
								</g>
							</svg>
						</a>
					</li>
					<li>
						<a href="https://x.com/">
							<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
								<g clip-path="url(#clip0_13439_102345)">
									<path d="M3.75 3.125H7.5L16.25 16.875H12.5L3.75 3.125Z" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
									<path d="M8.89687 11.2129L3.75 16.8746" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
									<path d="M16.2484 3.125L11.1016 8.78672" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
								</g>
							</svg>
						</a>
					</li>
					<li>
						<a href="https://www.instagram.com/">
							<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
								<g clip-path="url(#clip0_13439_102351)">
									<path d="M10 13.125C11.7259 13.125 13.125 11.7259 13.125 10C13.125 8.27411 11.7259 6.875 10 6.875C8.27411 6.875 6.875 8.27411 6.875 10C6.875 11.7259 8.27411 13.125 10 13.125Z" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
									<path d="M13.75 2.5H6.25C4.17893 2.5 2.5 4.17893 2.5 6.25V13.75C2.5 15.8211 4.17893 17.5 6.25 17.5H13.75C15.8211 17.5 17.5 15.8211 17.5 13.75V6.25C17.5 4.17893 15.8211 2.5 13.75 2.5Z" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
									<path d="M14.0625 6.71875C14.494 6.71875 14.8438 6.36897 14.8438 5.9375C14.8438 5.50603 14.494 5.15625 14.0625 5.15625C13.631 5.15625 13.2812 5.50603 13.2812 5.9375C13.2812 6.36897 13.631 6.71875 14.0625 6.71875Z" fill="#1C1C1C" />
								</g>
							</svg>
						</a>
					</li>
				</ul>
			</div>

			<div class="divider mb-26"></div>

			<div class="divider mb-40"></div>

			<!-- Comments -->
			<p class="h3 mb-20">
				@Model.Comments.Count Comment@(Model.Comments.Count != 1 ? "s" : "")
			</p>

			<div class="flex flex-col gap-24 mb-42">
				@foreach (var comment in Model.Comments)
				{
					<div class="comments-post">
						<div class="avatar">
							<div class="comment-box__avatar guest">
								@comment.AuthorName.Substring(0, Math.Min(2, comment.AuthorName.Length)).ToUpper()
							</div>
						</div>
						<div class="content">
							<p class="h5 mb-4">@comment.AuthorName</p>
							<p class="text-secondary text-sm mb-12">
								@{
									var timeDiff = DateTime.UtcNow - comment.CreatedDate;
									if (timeDiff.TotalDays < 1)
									{
										<text>Today</text>
									}
									else if (timeDiff.TotalDays < 2)
									{
										<text>1 day ago</text>
									}
									else
									{
										<text>@((int)timeDiff.TotalDays) days ago</text>
									}
								}
							</p>
							<p class="text-secondary h7 mb-12">@comment.Content</p>
						</div>
					</div>
				}
			</div>

			<!-- Comment Form -->
			<form asp-controller="Blog" asp-action="AddComment" method="post" class="blog-detail-comment-form">
				@Html.AntiForgeryToken()
				<input type="hidden" name="BlogPostId" value="@Model.Id" />
				<p class="h3 mb-24 capitalize">Leave A comment</p>
				<div class="grid grid-cols-2 gap-22 mb-16 md-grid-cols-1">
					<div class="md-col-span-2">
						<p class="mb-8">Your Name (Public)</p>
						<input class="active input-large" id="name-comment" name="AuthorName" type="text" placeholder="Your Name" required="">
					</div>
					<div class="md-col-span-2">
						<p class="mb-8">Your email (private)</p>
						<input class="input-large" name="AuthorEmail" id="email-comment" type="email" placeholder="your@email.com" required="">
					</div>
					<div class="col-span-2 padding-0">
						<p class="mb-8">Comment</p>
						<textarea placeholder="Write your comment here" rows="3" tabindex="5" name="Content" class="message" id="comment" required></textarea>
					</div>
				</div>

				<label class="filter-checkbox style-2 style-3 mb-28">
					<input type="checkbox" name="saveInfo" value="true">
					<span>Save your name, email for the next time review</span>
				</label>
				<button type="submit" class="btn btn-primary-3 btn-large font-weight-600 capitalize">Post Comment</button>
			</form>
		</div>

		<!-- Sidebar -->
		<div class="innerpage__sidebar">
			<form asp-controller="Blog" asp-action="Index" method="get" class="widget-search w-full mb-34">
				<input class="input-normal" type="text" name="q" required placeholder="Search posts...">
				<button type="submit" class="widget-search-btn">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<g clip-path="url(#clip0_13399_10504)">
							<path d="M10.5 18C14.6421 18 18 14.6421 18 10.5C18 6.35786 14.6421 3 10.5 3C6.35786 3 3 6.35786 3 10.5C3 14.6421 6.35786 18 10.5 18Z" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
							<path d="M15.8047 15.8047L21.0012 21.0012" stroke="#1C1C1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
						</g>
					</svg>
				</button>
			</form>

			<!-- Author -->
			<div class="mb-32">
				<div class="listing-details--contact-dealer style-3 mb-20">
					@if (!string.IsNullOrEmpty(Model.AuthorAvatarUrl))
					{
						<img src="@Model.AuthorAvatarUrl" alt="@Model.AuthorName">
					}
					else
					{
						<img src="~/assets/images/avatar/contact-avatar.png" alt="@Model.AuthorName">
					}
					<div class="content">
						<a href="#" class="h4 mb-8 font-weight-600">@(Model.AuthorName ?? "Admin")</a>
						<p class="text-secondary">Author</p>
					</div>
				</div>
			</div>

			<div class="divider mb-32 w-full"></div>

			<!-- Categories -->
			<p class="h4 mb-16">Categories</p>
			<ul class="widget-categories mb-32">
				@foreach (var category in categories)
				{
					<li>
						<a asp-controller="Blog" asp-action="Index" asp-route-category="@category.Slug" class="@(Model.CategoryName == category.Name ? "active" : "")">
							<span class="label">@category.Name</span>
						</a>
					</li>
				}
			</ul>

			<div class="divider mb-32 w-full"></div>

			<!-- Recent posts -->
			<p class="h4 mb-16 capitalize">Recent posts</p>
			<div class="mb-32">
				@foreach (var post in recentPosts)
				{
					<a asp-controller="Blog" asp-action="Detail" asp-route-slug="@post.Slug" class="recent-post overflow-hidden mb-16">
						<div class="image">
							@if (!string.IsNullOrEmpty(post.ThumbnailUrl))
							{
								<img class="post--img flex" src="@post.ThumbnailUrl" alt="@post.Title">
							}
							else
							{
								<img class="post--img flex" src="~/assets/images/blog/post-25.jpg" alt="@post.Title">
							}
						</div>
						<div class="content">
							<div class="flex gap-12 md-gap-6 justify-start mb-6">
								<span class="text-xs">by Admin</span>
								<span class="text-xs">@post.PublishedAt?.ToString("MMM. d, yyyy")</span>
								<span class="text-xs text-highlight uppercase text-underline">@(post.Category?.Name ?? "")</span>
							</div>
							<p class="title h7">@post.Title</p>
						</div>
					</a>
					<div class="divider mb-16 w-full"></div>
				}
			</div>

			<div class="divider mb-32 w-full"></div>

			<!-- Newsletter -->
			<p class="h4 mb-18">Subscribe Newsletter</p>
			<form action="#" class="widget-search w-full mb-34">
				<input class="input-normal" type="email" name="newsletter-email" required placeholder="Email address">
				<button type="submit" class="widget-search-btn">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M21.3112 2.689C21.1226 2.5005 20.8871 2.36569 20.629 2.29846C20.371 2.23122 20.0997 2.234 19.843 2.3065H19.829L1.83461 7.7665C1.54248 7.85069 1.28283 8.02166 1.09007 8.25676C0.897302 8.49185 0.780525 8.77997 0.75521 9.08294C0.729895 9.3859 0.797238 9.6894 0.948314 9.95323C1.09939 10.2171 1.32707 10.4287 1.60117 10.5602L9.56242 14.4377L13.4343 22.3943C13.5547 22.6513 13.7462 22.8685 13.9861 23.0201C14.226 23.1718 14.5042 23.2517 14.788 23.2502C14.8312 23.2502 14.8743 23.2484 14.9174 23.2446C15.2201 23.2201 15.5081 23.1036 15.7427 22.9107C15.9773 22.7178 16.1473 22.4578 16.2299 22.1656L21.6862 4.17119C21.6862 4.1665 21.6862 4.16181 21.6862 4.15712C21.7596 3.90115 21.7636 3.63024 21.6977 3.37223C21.6318 3.11421 21.4984 2.8784 21.3112 2.689Z" fill="#1C1C1C" />
					</svg>
				</button>
			</form>

			<div class="divider mb-32 w-full"></div>

			<!-- Tags -->
			@if (allTags.Any())
			{
				<p class="h4 mb-16">Tags</p>
				<ul class="widget-tags">
					@foreach (var tag in allTags)
					{
						<li>
							<a asp-controller="Blog" asp-action="Index" asp-route-tag="@tag.Name" class="@(Model.Tags.Contains(tag.Name) ? "active" : "")">@tag.Name</a>
						</li>
					}
				</ul>
			}
		</div>
	</div>
</section>

<!-- Related Articles -->
@if (Model.RelatedPosts.Any())
{
	<section class="py-100">
		<div class="container">
			<h2 class="mb-12">Related Articles</h2>
			<p class="h7 text-secondary mb-40">
				Get the latest insights, expert tips, and updates to stay informed and inspired.
			</p>
			<div class="swiper-container swiper-news">
				<div class="swiper-wrapper">
					@foreach (var post in Model.RelatedPosts)
					{
						<div class="swiper-slide">
							<a asp-controller="Blog" asp-action="Detail" asp-route-slug="@post.Slug" class="post-style-2 overflow-hidden">
								@if (!string.IsNullOrEmpty(post.ThumbnailUrl))
								{
									<img class="post--img flex" src="@post.ThumbnailUrl" alt="@post.Title">
								}
								else
								{
									<img class="post--img flex" src="~/assets/images/blog/post-4.jpg" alt="@post.Title">
								}
								<div class="content">
									<p class="h5 text-white mb-8 title">@post.Title</p>
									<div class="flex gap-8 justify-start">
										<span class="text-white text-xs">by @(post.AuthorName ?? "Admin")</span>
										<span class="text-white text-xs">@post.PublishedAt?.ToString("MMM. d, yyyy")</span>
										<span class="text-xs text-highlight uppercase text-underline">@post.CategoryName</span>
									</div>
								</div>
							</a>
						</div>
					}
				</div>
				<div class="swiper-pagination pagination-dark pagination-style pagination-swiper-news mt-35"></div>
			</div>
		</div>
	</section>
}