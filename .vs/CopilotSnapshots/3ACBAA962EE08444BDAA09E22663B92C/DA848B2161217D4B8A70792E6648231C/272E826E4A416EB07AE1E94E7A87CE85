	<script>
		// Dashboard Sidebar Toggle (for mobile/tablet <= 1200px)
		$(document).ready(function() {
			var $dashboardToggleBtn = $('#dashboardToggleBtn');
			var $dashboardSidebar = $('.dashboard-sidebar');
			var $dashboardContainer = $('.dashboard-container');
			var $body = $('body');

			// Toggle sidebar on button click
			$dashboardToggleBtn.on('click', function(e) {
				e.preventDefault();
				$dashboardSidebar.toggleClass('active');
				$dashboardContainer.toggleClass('sidebar-open');
				$body.toggleClass('dashboard-sidebar-open');
				$(this).toggleClass('active');
			});

			// Close sidebar when clicking outside (on mobile)
			$(document).on('click', function(e) {
				if ($(window).width() <= 1200) {
					if ($dashboardSidebar.hasClass('active')) {
						if (!$(e.target).closest('.dashboard-sidebar').length &&
							!$(e.target).closest('#dashboardToggleBtn').length) {
							$dashboardSidebar.removeClass('active');
							$dashboardContainer.removeClass('sidebar-open');
							$body.removeClass('dashboard-sidebar-open');
							$dashboardToggleBtn.removeClass('active');
						}
					}
				}
			});

			// Handle window resize
			$(window).on('resize', function() {
				if ($(window).width() > 1200) {
					// Desktop: always show sidebar, remove active classes
					$dashboardSidebar.removeClass('active');
					$dashboardContainer.removeClass('sidebar-open');
					$body.removeClass('dashboard-sidebar-open');
					$dashboardToggleBtn.removeClass('active');
				}
			});
		});

		// Reviews filtering by rating and sorting by date
		$(document).ready(function() {
			var selectedRating = 'all'; // 'all' or '1', '2', '3', '4', '5'
			var sortOrder = 'desc'; // 'desc' or 'asc'

			// Store all original comment-boxes
			var $commentsContainer = $('.comments.style2');
			var allCommentBoxes = null;

			// Initialize: Clone and store all original comment-boxes
			function initializeCommentBoxes() {
				if (allCommentBoxes === null) {
					allCommentBoxes = $commentsContainer.find('.comment-box').map(function() {
						return $(this).clone(true)[0]; // Clone with events
					}).get();
				}
			}

			// Initialize on page load
			initializeCommentBoxes();

			// Helper function: Get date from comment-box and parse to Date object
			function getDate($commentBox) {
				var dateText = $commentBox.find('.text-secondary.text-sm').text().trim();
				if (!dateText) return new Date(0); // Return epoch if no date found

				// Parse date like "August 13, 2025"
				var date = new Date(dateText);
				return isNaN(date.getTime()) ? new Date(0) : date;
			}

			// Filter and sort reviews
			function filterAndSortReviews() {
				// Ensure we have original comment boxes
				if (allCommentBoxes === null) {
					initializeCommentBoxes();
				}

				// Start with all original comment boxes (clone them)
				var $commentBoxes = allCommentBoxes.map(function(box) {
					return $(box).clone(true)[0];
				});

				// Filter by rating if not 'all'
				if (selectedRating !== 'all') {
					var ratingFilter = parseInt(selectedRating);
					$commentBoxes = $commentBoxes.filter(function(box) {
						var $box = $(box);
						var boxRating = parseInt($box.data('start')) || 0;
						return boxRating === ratingFilter;
					});
				}

				// Sort by date
				$commentBoxes.sort(function(a, b) {
					var $a = $(a);
					var $b = $(b);
					var dateA = getDate($a);
					var dateB = getDate($b);

					if (sortOrder === 'desc') {
						return dateB - dateA; // Newest first
					} else {
						return dateA - dateB; // Oldest first
					}
				});

				// Re-append filtered and sorted items
				$commentsContainer.empty();
				$commentBoxes.forEach(function(box) {
					$commentsContainer.append(box);
				});
			}

			// Rating dropdown click handler
			$(document).on('click', '#ratingDropdownMenu .core-dropdown__option', function(e) {
				e.preventDefault();
				var $option = $(this);
				var value = $option.data('value');

				selectedRating = value;

				// Update active state
				$('#ratingDropdownMenu .core-dropdown__option').removeClass('active');
				$option.addClass('active');

				// Update button text
				if (value === 'all') {
					$('#ratingDropdownBtn .core-dropdown__selected').text('All Ratings');
				} else {
					$('#ratingDropdownBtn .core-dropdown__selected').text('Rating ' + value);
				}

				// Filter and sort reviews
				filterAndSortReviews();
			});

			// Sort dropdown click handler
			$(document).on('click', '#sortDateDropdownMenu .core-dropdown__option', function(e) {
				e.preventDefault();
				var $option = $(this);
				var value = $option.data('value');

				sortOrder = value;

				// Update active state
				$('#sortDateDropdownMenu .core-dropdown__option').removeClass('active');
				$option.addClass('active');

				// Update button text
				$('#sortDateDropdownBtn .core-dropdown__selected').text(value === 'desc' ? 'Desc' : 'Asc');

				// Filter and sort reviews
				filterAndSortReviews();
			});
		});
	</script>
