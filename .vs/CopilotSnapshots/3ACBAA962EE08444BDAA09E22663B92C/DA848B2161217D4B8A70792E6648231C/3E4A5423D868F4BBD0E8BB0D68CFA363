	<script>
		// Dashboard Sidebar Toggle (for mobile/tablet <= 1200px)
		$(document).ready(function() {
			var $dashboardToggleBtn = $('#dashboardToggleBtn');
			var $dashboardSidebar = $('.dashboard-sidebar');
			var $dashboardContainer = $('.dashboard-container');
			var $body = $('body');

			// Toggle sidebar on button click
			$dashboardToggleBtn.on('click', function(e) {
				e.preventDefault();
				$dashboardSidebar.toggleClass('active');
				$dashboardContainer.toggleClass('sidebar-open');
				$body.toggleClass('dashboard-sidebar-open');
				$(this).toggleClass('active');
			});

			// Close sidebar when clicking outside (on mobile)
			$(document).on('click', function(e) {
				if ($(window).width() <= 1200) {
					if ($dashboardSidebar.hasClass('active')) {
						if (!$(e.target).closest('.dashboard-sidebar').length &&
							!$(e.target).closest('#dashboardToggleBtn').length) {
							$dashboardSidebar.removeClass('active');
							$dashboardContainer.removeClass('sidebar-open');
							$body.removeClass('dashboard-sidebar-open');
							$dashboardToggleBtn.removeClass('active');
						}
					}
				}
			});

			// Handle window resize
			$(window).on('resize', function() {
				if ($(window).width() > 1200) {
					// Desktop: always show sidebar, remove active classes
					$dashboardSidebar.removeClass('active');
					$dashboardContainer.removeClass('sidebar-open');
					$body.removeClass('dashboard-sidebar-open');
					$dashboardToggleBtn.removeClass('active');
				}
			});
		});

		// Remove cart-item when clicking cart-item__remove
		$(document).on('click', '.cart-item__remove', function(e) {
			e.preventDefault();
			e.stopPropagation();

			var $removeBtn = $(this);
			var $cartItem = $removeBtn.closest('.cart-item');

			if ($cartItem.length) {
				// Optional: Add fade out animation before removing
				$cartItem.fadeOut(300, function() {
					$(this).remove();

					// Check if there are any cart-items left
					var $remainingItems = $('.cart-items .cart-item');
					if ($remainingItems.length === 0) {
						// Remove pagination-bottom if no cart-items remain
						$('#pagination-bottom').fadeOut(300, function() {
							$(this).remove();
						});
					}
				});
			}
		});
	</script>
