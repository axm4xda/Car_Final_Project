@model Car_Project.ViewModels.Home.HomeIndexViewModel

<!-- page-title -->
<form action="#">
	<section class="page-title flex h-706">
		<div class="swiper-container page-title--slider sw-single">
			<div class="swiper-wrapper">
				<div class="swiper-slide">
					<div class="tp-showcase-slider-bg" data-background="/assets/images/page-title/banner-1.jpg"></div>
				</div>
				<div class="swiper-slide">
					<div class="tp-showcase-slider-bg" data-background="/assets/images/page-title/banner-2.jpg"></div>
				</div>
				<div class="swiper-slide">
					<div class="tp-showcase-slider-bg" data-background="/assets/images/page-title/banner-3.jpg"></div>
				</div>
				<div class="swiper-slide">
					<div class="tp-showcase-slider-bg" data-background="/assets/images/page-title/banner-5.jpg"></div>
				</div>
			</div>
		</div>

		<!-- Search Cars Section -->
		<div class="search-cars container margin-top-auto margin-bottom-auto">
			<h1 class="search-cars__title wow fadeInUp" data-wow-delay="0.1s">Search Cars Near You - Buy Today!</h1>

			<div class="flat-tabs mb-16 wow fadeInUp" data-wow-delay="0.3s">
				<div class="overflow-x-auto">
					<ul class="menu-tab menu-tab-style1 text-white">
						<li class="active"><span class="text-white font-weight-600">All Car</span></li>
						<li><span class="text-white font-weight-600">New Car</span></li>
						<li><span class="text-white font-weight-600">Used Car</span></li>
					</ul>
				</div>
			</div>

			<!-- Primary Search Filters -->
			<div class="search-cars__filters wow fadeInUp" data-wow-delay="0.5s">
				<div class="search-cars__select-wrapper">
					<div class="search-cars__select bg-white filter-select-dropdown" data-name="Brand">
						<label for="BrandSelectToggle" class="search-cars__label">Select Brand</label>
						<input type="checkbox" id="BrandSelectToggle" class="filter-select-dropdown__toggle">
						<label for="BrandSelectToggle" class="filter-select-dropdown__text">
							<span>All Brand</span>
						</label>
						<div class="filter-select-dropdown__menu">
							<div class="filter-select-dropdown__list">
								<label class="filter-checkbox">
									<input type="checkbox" name="brand" value="all" checked>
									<span>All Brand</span>
								</label>
								@foreach (var brand in Model.BrandNames)
								{
									<label class="filter-checkbox">
										<input type="checkbox" name="brand" value="@brand">
										<span>@brand</span>
									</label>
								}
							</div>
						</div>
					</div>
				</div>
				<div class="search-cars__select-wrapper">
					<div class="search-cars__select bg-white filter-select-dropdown" data-name="Model">
						<label for="ModelSelectToggle" class="search-cars__label">Select Model</label>
						<input type="checkbox" id="ModelSelectToggle" class="filter-select-dropdown__toggle">
						<label for="ModelSelectToggle" class="filter-select-dropdown__text">
							<span>All Model</span>
						</label>
						<div class="filter-select-dropdown__menu">
							<div class="filter-select-dropdown__list">
								<label class="filter-checkbox">
									<input type="checkbox" name="model" value="all" checked>
									<span>All Model</span>
								</label>
							</div>
						</div>
					</div>
				</div>
				<div class="search-cars__select-wrapper">
					<div class="search-cars__select bg-white filter-select-dropdown" data-name="Miles">
						<label for="MilesSelectToggle" class="search-cars__label">Select Miles</label>
						<input type="checkbox" id="MilesSelectToggle" class="filter-select-dropdown__toggle">
						<label for="MilesSelectToggle" class="filter-select-dropdown__text">
							<span>All miles</span>
						</label>
						<div class="filter-select-dropdown__menu">
							<div class="filter-select-dropdown__list">
								<label class="filter-checkbox">
									<input type="checkbox" name="miles" value="all" checked>
									<span>All miles</span>
								</label>
								<label class="filter-checkbox">
									<input type="checkbox" name="miles" value="1">
									<span>0-10k</span>
								</label>
								<label class="filter-checkbox">
									<input type="checkbox" name="miles" value="2">
									<span>10k-50k</span>
								</label>
							</div>
						</div>
					</div>
				</div>
				<div class="search-cars__select-wrapper">
					<div class="search-cars__select bg-white filter-select-dropdown" data-name="Price">
						<label for="MaxPriceSelectToggle" class="search-cars__label">Max Price</label>
						<input type="checkbox" id="MaxPriceSelectToggle" class="filter-select-dropdown__toggle">
						<label for="MaxPriceSelectToggle" class="filter-select-dropdown__text">
							<span>All Price</span>
						</label>
						<div class="filter-select-dropdown__menu">
							<div class="filter-select-dropdown__list">
								<label class="filter-checkbox">
									<input type="checkbox" name="price" value="all" checked>
									<span>All Price</span>
								</label>
								<label class="filter-checkbox">
									<input type="checkbox" name="price" value="1">
									<span>$0-$10k</span>
								</label>
								<label class="filter-checkbox">
									<input type="checkbox" name="price" value="2">
									<span>$10k-$20k</span>
								</label>
							</div>
						</div>
					</div>
				</div>

				<!-- Filter Icon Button -->
				<div class="search-cars__filter" id="filterToggle">
					<img src="~/assets/icons/filter.svg" alt="Filter">
				</div>

				<button type="submit" class="search-cars__search flex items-center gap-8 justify-center md-w-full">
					<img src="~/assets/icons/search.svg" alt="search">
					Show @Model.TotalMatchCount.ToString("N0") Matches
				</button>
			</div>

			<!-- Advanced Filters Panel -->
			<div class="search-cars__advanced" id="advancedFilters">
				<div class="search-cars__advanced-content">
					<div class="search-cars__advanced-row">
						<div class="search-cars__select-wrapper">
							<div class="bg-white filter-select-dropdown style2" data-name="fuel-type">
								<input type="checkbox" id="fuel-type" class="filter-select-dropdown__toggle">
								<label for="fuel-type" class="filter-select-dropdown__text">
									<span>Fuel Type</span>
								</label>
								<div class="filter-select-dropdown__menu">
									<div class="filter-select-dropdown__list">
										<label class="filter-checkbox">
											<input type="checkbox" name="fuelType" value="Fuel" checked>
											<span>Fuel Type</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="fuelType" value="Petrol">
											<span>Petrol</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="fuelType" value="Diesel">
											<span>Diesel</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="fuelType" value="Electric">
											<span>Electric</span>
										</label>
									</div>
								</div>
							</div>
						</div>

						<div class="search-cars__select-wrapper">
							<div class="bg-white filter-select-dropdown style2" data-name="Transmission">
								<input type="checkbox" id="Transmission" class="filter-select-dropdown__toggle">
								<label for="Transmission" class="filter-select-dropdown__text">
									<span>Transmission</span>
								</label>
								<div class="filter-select-dropdown__menu">
									<div class="filter-select-dropdown__list">
										<label class="filter-checkbox">
											<input type="checkbox" name="transmission" value="Transmission">
											<span>Transmission</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="transmission" value="Manual">
											<span>Manual</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="transmission" value="Automatic">
											<span>Automatic</span>
										</label>
									</div>
								</div>
							</div>
						</div>

						<div class="search-cars__select-wrapper">
							<div class="bg-white filter-select-dropdown style2" data-name="DriveType">
								<input type="checkbox" id="DriveType" class="filter-select-dropdown__toggle">
								<label for="DriveType" class="filter-select-dropdown__text">
									<span>Drive Type</span>
								</label>
								<div class="filter-select-dropdown__menu">
									<div class="filter-select-dropdown__list">
										<label class="filter-checkbox">
											<input type="checkbox" name="driveType" value="FWD" checked>
											<span>FWD</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="driveType" value="RWD">
											<span>RWD</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="driveType" value="AWD">
											<span>AWD</span>
										</label>
									</div>
								</div>
							</div>
						</div>

						<div class="search-cars__select-wrapper">
							<div class="bg-white filter-select-dropdown style2" data-name="colorType">
								<input type="checkbox" id="colorType" class="filter-select-dropdown__toggle">
								<label for="colorType" class="filter-select-dropdown__text">
									<span>Color</span>
								</label>
								<div class="filter-select-dropdown__menu">
									<div class="filter-select-dropdown__list">
										<label class="filter-checkbox">
											<input type="checkbox" name="color" value="Color" checked>
											<span>Color</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="color" value="Red">
											<span>Red</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="color" value="Blue">
											<span>Blue</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="color" value="Black">
											<span>Black</span>
										</label>
									</div>
								</div>
							</div>
						</div>

						<div class="search-cars__select-wrapper">
							<div class="bg-white filter-select-dropdown style2" data-name="Cylinders">
								<input type="checkbox" id="Cylinders" class="filter-select-dropdown__toggle">
								<label for="Cylinders" class="filter-select-dropdown__text">
									<span>Cylinders</span>
								</label>
								<div class="filter-select-dropdown__menu">
									<div class="filter-select-dropdown__list">
										<label class="filter-checkbox">
											<input type="checkbox" name="cylinders" value="all" checked>
											<span>Cylinders</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="cylinders" value="4">
											<span>4</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="cylinders" value="3">
											<span>3</span>
										</label>
										<label class="filter-checkbox">
											<input type="checkbox" name="cylinders" value="2">
											<span>2</span>
										</label>
									</div>
								</div>
							</div>
						</div>
						<div class="search-cars__range">
							<p class="search-cars__range-label">
								Year: <span id="yearMin">2015</span> - <span id="yearMax">2026</span>
							</p>
							<div class="search-cars__range-wrapper" id="yearRangeWrapper">
								<div id="slider-range" data-min="2015" data-max="2026" data-step="1" data-values="2015, 2026"></div>
							</div>
						</div>
					</div>

					<div class="divider mt-28 mb-24"></div>

					<div class="search-cars__features collapse">
						<p class="h3 search-cars__features-title flex items-center gap-8 collapse-title">
							Features
							<span class="icon md-block">-</span>
						</p>
						<div class="search-cars__features-grid collapse-content">
							<div class="form-group">
								<input type="checkbox" id="TouchScreen" checked>
								<label for="TouchScreen">Touch Screen</label>
							</div>
							<div class="form-group">
								<input type="checkbox" id="AntiLockBrakingSystem">
								<label for="AntiLockBrakingSystem">Anti Lock Braking System</label>
							</div>
							<div class="form-group">
								<input type="checkbox" id="AirConditioner">
								<label for="AirConditioner">Air Conditioner</label>
							</div>
							<div class="form-group">
								<input type="checkbox" id="AlloyWheels" checked>
								<label for="AlloyWheels">Alloy Wheels</label>
							</div>
							<div class="form-group">
								<input type="checkbox" id="BluetoothConnectivity">
								<label for="BluetoothConnectivity">Bluetooth Connectivity</label>
							</div>
							<div class="form-group">
								<input type="checkbox" id="SunRoof">
								<label for="SunRoof">Sun Roof</label>
							</div>
							<div class="form-group">
								<input type="checkbox" id="PowerWindowsFront">
								<label for="PowerWindowsFront">Power Windows Front</label>
							</div>
							<div class="form-group">
								<input type="checkbox" id="PowerWindowsRear">
								<label for="PowerWindowsRear">Power Windows Rear</label>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="wow fadeInUp" data-wow-delay="0.7s">
				<div class="category-list flex-wrap mt-32">
