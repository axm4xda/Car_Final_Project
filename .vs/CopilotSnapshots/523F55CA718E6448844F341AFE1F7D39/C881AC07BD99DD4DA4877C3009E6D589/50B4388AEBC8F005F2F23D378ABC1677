@model Car
@{
    ViewData["Title"] = "Maşın Redaktə";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var brands = (SelectList)ViewBag.Brands;
    var allFeatures = (List<CarFeature>)ViewBag.AllFeatures;
    var selectedFeatureIds = (List<int>)ViewBag.SelectedFeatureIds;
}

<div class="admin-card">
    <h3 class="admin-card-title" style="margin-bottom:24px;">Maşın Redaktə Et — @Model.Title</h3>

    <form asp-action="CarEdit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="form-row">
            <div class="form-group">
                <label>Başlıq *</label>
                <input type="text" name="Title" class="form-control" required value="@Model.Title">
            </div>
            <div class="form-group">
                <label>Marka *</label>
                <select name="BrandId" class="form-control" required>
                    @foreach (var b in brands) { <option value="@b.Value" selected="@(b.Value == Model.BrandId.ToString())">@b.Text</option> }
                </select>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Qiymət ($) *</label>
                <input type="number" name="Price" class="form-control" required step="0.01" value="@Model.Price">
            </div>
            <div class="form-group">
                <label>Aylıq Ödəniş ($)</label>
                <input type="number" name="MonthlyPayment" class="form-control" step="0.01" value="@Model.MonthlyPayment">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>İl *</label>
                <input type="number" name="Year" class="form-control" required value="@Model.Year">
            </div>
            <div class="form-group">
                <label>Yürüş (km) *</label>
                <input type="number" name="Mileage" class="form-control" required value="@Model.Mileage">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Yanacaq Tipi *</label>
                <select name="FuelType" class="form-control">
                    @foreach (var ft in Enum.GetValues<FuelType>()) { <option value="@ft" selected="@(ft == Model.FuelType)">@ft</option> }
                </select>
            </div>
            <div class="form-group">
                <label>Transmissiya *</label>
                <select name="Transmission" class="form-control">
                    @foreach (var t in Enum.GetValues<TransmissionType>()) { <option value="@t" selected="@(t == Model.Transmission)">@t</option> }
                </select>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Vəziyyət *</label>
                <select name="Condition" class="form-control">
                    @foreach (var c in Enum.GetValues<CarCondition>()) { <option value="@c" selected="@(c == Model.Condition)">@c</option> }
                </select>
            </div>
            <div class="form-group">
                <label>Bədən Tipi</label>
                <input type="text" name="BodyStyle" class="form-control" value="@Model.BodyStyle">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Sürücü Tipi</label>
                <input type="text" name="DriveType" class="form-control" value="@Model.DriveType">
            </div>
            <div class="form-group">
                <label>Rəng</label>
                <input type="text" name="Color" class="form-control" value="@Model.Color">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Daxili Rəng</label>
                <input type="text" name="InteriorColor" class="form-control" value="@Model.InteriorColor">
            </div>
            <div class="form-group">
                <label>Silindr Sayı</label>
                <input type="number" name="Cylinders" class="form-control" value="@Model.Cylinders">
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Qapı Sayı</label>
                <input type="number" name="DoorCount" class="form-control" value="@Model.DoorCount">
            </div>
            <div class="form-group">
                <label>Badge</label>
                <input type="text" name="Badge" class="form-control" value="@Model.Badge">
            </div>
        </div>

        <div class="form-group">
            <label>Təsvir</label>
            <textarea name="Description" class="form-control" rows="4">@Model.Description</textarea>
        </div>

        @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
        {
            <div class="form-group">
                <label>Mövcud Thumbnail</label>
                <img src="@Model.ThumbnailUrl" style="width:120px;border-radius:8px;margin-bottom:8px;" alt="">
            </div>
        }

        <div class="form-group">
            <label>Yeni Thumbnail (dəyişmək üçün)</label>
            <input type="file" name="thumbnailFile" class="form-control" accept="image/*">
        </div>

        @if (Model.Images.Any())
        {
            <div class="form-group">
                <label>Mövcud Şəkillər</label>
                <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:6px;">
                    @foreach (var img in Model.Images)
                    {
                        <div style="position:relative;">
                            <img src="@img.ImageUrl" style="width:100px;height:100px;object-fit:cover;border-radius:8px;" alt="">
                            <form asp-action="CarImageDelete" asp-route-id="@img.Id" method="post" style="position:absolute;top:-6px;right:-6px;" onsubmit="return confirm('Bu şəkli silmək istəyirsiniz?')">
                                @Html.AntiForgeryToken()
                                <button style="width:22px;height:22px;border-radius:50%;background:#dc2626;color:#fff;border:none;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;">✕</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="form-group">
            <label>Əlavə Şəkillər (çoxlu seçim)</label>
            <input type="file" name="imageFiles" class="form-control" accept="image/*" multiple>
        </div>

        @if (allFeatures.Any())
        {
            <div class="form-group">
                <label>Xüsusiyyətlər</label>
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:6px;">
                    @foreach (var f in allFeatures)
                    {
                        <label class="form-check">
                            <input type="checkbox" name="featureIds" value="@f.Id" @(selectedFeatureIds.Contains(f.Id) ? "checked" : "")>
                            @f.Name
                        </label>
                    }
                </div>
            </div>
        }

        <div style="display:flex;gap:12px;margin-top:24px;">
            <button type="submit" class="btn-admin primary">💾 Yadda Saxla</button>
            <a asp-action="Cars" class="btn-admin ghost">← Geri</a>
        </div>
    </form>
</div>
