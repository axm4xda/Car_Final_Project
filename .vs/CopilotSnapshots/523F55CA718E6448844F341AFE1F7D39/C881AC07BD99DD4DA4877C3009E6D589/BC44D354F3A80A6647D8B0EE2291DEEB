        {
            if (!string.IsNullOrWhiteSpace(name))
            {
                var cat = new ProductCategory
                {
                    Name = name.Trim(),
                    Slug = slug?.Trim() ?? name.ToLower().Replace(" ", "-"),
                    CreatedDate = DateTime.UtcNow
                };
                if (iconFile != null) cat.IconUrl = await _fileService.UploadAsync(iconFile, "uploads/product-categories");
                _db.ProductCategories.Add(cat);
                await _db.SaveChangesAsync();
                TempData["Success"] = "Kateqoriya əlavə edildi.";
            }
            return RedirectToAction(nameof(ProductCategories));
        }

        [HttpPost, ValidateAntiForgeryToken]
        public async Task<IActionResult> ProductCategoryEdit(int id, string name, string? slug)
        {
            var cat = await _db.ProductCategories.FindAsync(id);
            if (cat != null && !string.IsNullOrWhiteSpace(name))
            {
                cat.Name = name.Trim();
                cat.Slug = slug?.Trim();
                await _db.SaveChangesAsync();
                TempData["Success"] = "Kateqoriya yeniləndi.";
            }
            return RedirectToAction(nameof(ProductCategories));
        }

        [HttpPost, ValidateAntiForgeryToken]
        public async Task<IActionResult> ProductCategoryDelete(int id)
        {
            var cat = await _db.ProductCategories.FindAsync(id);
            if (cat == null) return NotFound();
            if (await _db.Products.AnyAsync(p => p.CategoryId == id))
            {
                TempData["Error"] = "Bu kateqoriyaya aid məhsullar var.";
                return RedirectToAction(nameof(ProductCategories));
            }
            _db.ProductCategories.Remove(cat);
            await _db.SaveChangesAsync();
            TempData["Success"] = "Kateqoriya silindi.";
            return RedirectToAction(nameof(ProductCategories));
        }

