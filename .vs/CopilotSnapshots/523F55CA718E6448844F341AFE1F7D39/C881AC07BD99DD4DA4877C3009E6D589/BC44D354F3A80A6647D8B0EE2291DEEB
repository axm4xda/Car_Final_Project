        [HttpPost, ValidateAntiForgeryToken]
        public async Task<IActionResult> BlogPostCreate(BlogPost post, IFormFile? thumbnailFile, int[]? tagIds)
        {
            post.CreatedDate = DateTime.UtcNow;
            if (string.IsNullOrWhiteSpace(post.Slug))
                post.Slug = post.Title.ToLower().Replace(" ", "-").Replace("ş", "s").Replace("ə", "e").Replace("ü", "u").Replace("ö", "o").Replace("ğ", "g").Replace("ı", "i").Replace("ç", "c");
            if (thumbnailFile != null) post.ThumbnailUrl = await _fileService.UploadAsync(thumbnailFile, "uploads/blog");
            _db.BlogPosts.Add(post);
            await _db.SaveChangesAsync();

            if (tagIds != null)
            {
                foreach (var tid in tagIds)
                    _db.BlogPostTags.Add(new BlogPostTag { BlogPostId = post.Id, BlogTagId = tid });
                await _db.SaveChangesAsync();
            }

            TempData["Success"] = "Blog yazısı əlavə edildi.";
            return RedirectToAction(nameof(BlogPosts));
        }

        public async Task<IActionResult> BlogPostEdit(int id)
        {
            ViewData["ActivePage"] = "BlogPosts";
            var post = await _db.BlogPosts.Include(p => p.PostTags).FirstOrDefaultAsync(p => p.Id == id);
            if (post == null) return NotFound();
            ViewBag.Categories = new SelectList(await _db.BlogCategories.ToListAsync(), "Id", "Name", post.CategoryId);
            ViewBag.AllTags = await _db.BlogTags.ToListAsync();
            ViewBag.SelectedTagIds = post.PostTags.Select(pt => pt.BlogTagId).ToList();
            return View(post);
        }

        [HttpPost, ValidateAntiForgeryToken]
        public async Task<IActionResult> BlogPostEdit(int id, BlogPost post, IFormFile? thumbnailFile, int[]? tagIds)
        {
            var existing = await _db.BlogPosts.Include(p => p.PostTags).FirstOrDefaultAsync(p => p.Id == id);
            if (existing == null) return NotFound();

            existing.Title = post.Title;
            existing.Slug = string.IsNullOrWhiteSpace(post.Slug)
                ? post.Title.ToLower().Replace(" ", "-")
                : post.Slug;
            existing.Summary = post.Summary;
            existing.Content = post.Content;
            existing.AuthorName = post.AuthorName;
            existing.AuthorAvatarUrl = post.AuthorAvatarUrl;
            existing.Status = post.Status;
            existing.CategoryId = post.CategoryId;
            if (post.Status == BlogStatus.Published && existing.PublishedAt == null)
                existing.PublishedAt = DateTime.UtcNow;

            if (thumbnailFile != null)
                existing.ThumbnailUrl = await _fileService.ReplaceAsync(existing.ThumbnailUrl ?? "", thumbnailFile, "uploads/blog");

            _db.BlogPostTags.RemoveRange(existing.PostTags);
            if (tagIds != null)
            {
                foreach (var tid in tagIds)
                    _db.BlogPostTags.Add(new BlogPostTag { BlogPostId = id, BlogTagId = tid });
            }

            await _db.SaveChangesAsync();
            TempData["Success"] = "Blog yazısı yeniləndi.";
            return RedirectToAction(nameof(BlogPosts));
        }

        [HttpPost, ValidateAntiForgeryToken]
        public async Task<IActionResult> BlogPostDelete(int id)
        {
            var post = await _db.BlogPosts.FindAsync(id);
