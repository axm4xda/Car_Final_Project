@using Microsoft.AspNetCore.Identity
@inject UserManager<Car_Project.Models.AppUser> _upUserManager
@{
    ViewData["Title"] = "Profilim";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var upUser = await _upUserManager.GetUserAsync(User);
    var upRoles = upUser != null ? await _upUserManager.GetRolesAsync(upUser) : new List<string>();
    var upRole = upRoles.FirstOrDefault() ?? "User";
}

<!-- breadcrumb -->
<section class="background-light">
    <div class="container">
        <ul class="breadcrumb">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><img src="~/assets/icons/right.svg" alt="right"></li>
            <li><span>Profilim</span></li>
        </ul>
    </div>
</section>

<div class="db-layout">
    @await Html.PartialAsync("_DashboardSidebar")

    <main class="db-content">
        <p class="h3 mb-32">Profilim</p>

        @if (upUser != null)
        {
            <!-- User Info Card -->
            <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:28px;margin-bottom:24px;">
                <div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;flex-wrap:wrap;">
                    <div style="width:72px;height:72px;border-radius:50%;background:#FF5722;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:700;color:#fff;flex-shrink:0;">
                        @upUser.FullName.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <p class="h4 mb-4">@upUser.FullName</p>
                        <p class="text-secondary text-sm">@upUser.Email</p>
                        <span style="display:inline-block;margin-top:6px;padding:3px 10px;font-size:11px;font-weight:600;background:#fff5f2;color:#FF5722;border-radius:20px;border:1px solid #ffd4c7;">@upRole</span>
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;">
                    <div>
                        <p class="text-sm text-secondary mb-4">Ad Soyad</p>
                        <p class="font-weight-600">@upUser.FullName</p>
                    </div>
                    <div>
                        <p class="text-sm text-secondary mb-4">Email</p>
                        <p class="font-weight-600">@upUser.Email</p>
                    </div>
                    <div>
                        <p class="text-sm text-secondary mb-4">Rol</p>
                        <p class="font-weight-600">@upRole</p>
                    </div>
                    <div>
                        <p class="text-sm text-secondary mb-4">Qeydiyyat tarixi</p>
                        <p class="font-weight-600">@upUser.CreatedDate.ToString("dd.MM.yyyy")</p>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div style="background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:28px;margin-bottom:24px;">
                <p class="h5 mb-20">Sürətli Keçidlər</p>
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;">
                    <a asp-controller="UserListing" asp-action="Index"
                       style="display:flex;flex-direction:column;align-items:center;gap:10px;padding:20px 16px;border:1px solid #e5e7eb;border-radius:12px;text-decoration:none;color:#1C1C1C;transition:border-color 0.2s,box-shadow 0.2s;"
                       onmouseover="this.style.borderColor='#FF5722';this.style.boxShadow='0 4px 12px rgba(255,87,34,0.12)';"
                       onmouseout="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M8 6H21" stroke="#FF5722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M8 12H21" stroke="#FF5722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M8 18H21" stroke="#FF5722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M3 6H3.01" stroke="#FF5722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M3 12H3.01" stroke="#FF5722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M3 18H3.01" stroke="#FF5722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span style="font-size:13px;font-weight:600;">Elanlarım</span>
                    </a>
                    <a asp-controller="Reviews" asp-action="Index"
                       style="display:flex;flex-direction:column;align-items:center;gap:10px;padding:20px 16px;border:1px solid #e5e7eb;border-radius:12px;text-decoration:none;color:#1C1C1C;transition:border-color 0.2s,box-shadow 0.2s;"
                       onmouseover="this.style.borderColor='#FF5722';this.style.boxShadow='0 4px 12px rgba(255,87,34,0.12)';"
                       onmouseout="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" stroke="#FF5722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span style="font-size:13px;font-weight:600;">Rəylər</span>
                    </a>
                    <a asp-controller="Message" asp-action="Index"
                       style="display:flex;flex-direction:column;align-items:center;gap:10px;padding:20px 16px;border:1px solid #e5e7eb;border-radius:12px;text-decoration:none;color:#1C1C1C;transition:border-color 0.2s,box-shadow 0.2s;"
                       onmouseover="this.style.borderColor='#FF5722';this.style.boxShadow='0 4px 12px rgba(255,87,34,0.12)';"
                       onmouseout="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M21 15C21 15.5304 20.7893 16.0391 20.4142 16.4142C20.0391 16.7893 19.5304 17 19 17H7L3 21V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H19C19.5304 3 20.0391 3.21071 20.4142 3.58579C20.7893 3.96086 21 4.46957 21 5V15Z" stroke="#FF5722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span style="font-size:13px;font-weight:600;">Canlı Söhbət</span>
                    </a>
                    <a asp-controller="ChangePassword" asp-action="Index"
                       style="display:flex;flex-direction:column;align-items:center;gap:10px;padding:20px 16px;border:1px solid #e5e7eb;border-radius:12px;text-decoration:none;color:#1C1C1C;transition:border-color 0.2s,box-shadow 0.2s;"
                       onmouseover="this.style.borderColor='#FF5722';this.style.boxShadow='0 4px 12px rgba(255,87,34,0.12)';"
                       onmouseout="this.style.borderColor='#e5e7eb';this.style.boxShadow='none';">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" stroke="#FF5722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M7 11V7C7 5.67392 7.52678 4.40215 8.46447 3.46447C9.40215 2.52678 10.6739 2 12 2C13.3261 2 14.5979 2.52678 15.5355 3.46447C16.4732 4.40215 17 5.67392 17 7V11" stroke="#FF5722" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span style="font-size:13px;font-weight:600;">Şifrə Dəyiş</span>
                    </a>
                </div>
            </div>
        }
        else
        {
            <div style="text-align:center;padding:60px 20px;">
                <p class="h5 text-secondary">Profil məlumatları tapılmadı.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-large mt-20">Ana Səhifəyə Qayıt</a>
            </div>
        }
    </main>
</div>