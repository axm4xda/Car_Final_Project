    <script>
        // Dashboard Sidebar Toggle (for mobile/tablet <= 1200px)
        $(document).ready(function() {
            var $dashboardToggleBtn = $('#dashboardToggleBtn');
            var $dashboardSidebar = $('.dashboard-sidebar');
            var $dashboardContainer = $('.dashboard-container');
            var $body = $('body');

            // Toggle sidebar on button click
            $dashboardToggleBtn.on('click', function(e) {
                e.preventDefault();
                $dashboardSidebar.toggleClass('active');
                $dashboardContainer.toggleClass('sidebar-open');
                $body.toggleClass('dashboard-sidebar-open');
                $(this).toggleClass('active');
            });

            // Close sidebar when clicking outside (on mobile)
            $(document).on('click', function(e) {
                if ($(window).width() <= 1200) {
                    if ($dashboardSidebar.hasClass('active')) {
                        if (!$(e.target).closest('.dashboard-sidebar').length &&
                            !$(e.target).closest('#dashboardToggleBtn').length) {
                            $dashboardSidebar.removeClass('active');
                            $dashboardContainer.removeClass('sidebar-open');
                            $body.removeClass('dashboard-sidebar-open');
                            $dashboardToggleBtn.removeClass('active');
                        }
                    }
                }
            });

            // Handle window resize
            $(window).on('resize', function() {
                if ($(window).width() > 1200) {
                    // Desktop: always show sidebar, remove active classes
                    $dashboardSidebar.removeClass('active');
                    $dashboardContainer.removeClass('sidebar-open');
                    $body.removeClass('dashboard-sidebar-open');
                    $dashboardToggleBtn.removeClass('active');
                }
            });
        });

        // Message: Delete message when clicking Delete
        $(document).on('click', '.message-item__options .core-dropdown__menu a', function(e) {
            e.preventDefault();
            var $link = $(this);
            var linkText = $link.text().trim();

            // Only handle Delete link
            if (linkText === 'Delete') {
                var $messageItem = $link.closest('.message-item');

                if ($messageItem.length) {
                    $messageItem.fadeOut(300, function() {
                        $(this).remove();
                    });
                }
            }
        });

        // Message: Send new message
        $(document).ready(function() {
            var $messageInput = $('.message-chat__input-field');
            var $sendButton = $('.message-chat__send');
            var $messageBody = $('.message-chat__body');

            // Send message on button click
            $sendButton.on('click', function(e) {
                e.preventDefault();
                sendMessage();
            });

            // Send message on Enter key
            $messageInput.on('keypress', function(e) {
                if (e.which === 13) { // Enter key
                    e.preventDefault();
                    sendMessage();
                }
            });

            function sendMessage() {
                var messageText = $messageInput.val().trim();

                if (!messageText) {
                    return; // Don't send empty messages
                }

                // Get current time
                var now = new Date();
                var hours = now.getHours();
                var minutes = now.getMinutes();
                var ampm = hours >= 12 ? 'PM' : 'AM';
                hours = hours % 12;
                hours = hours ? hours : 12; // the hour '0' should be '12'
                minutes = minutes < 10 ? '0' + minutes : minutes;
                var timeString = hours + ':' + minutes + ' ' + ampm;

                // Create message HTML (sent message)
                var messageHtml =
                    '<div class="message-item message-item--sent">' +
                        '<div class="message-item__bubble">' +
                            '<div class="message-item__options core-dropdown">' +
                                '<img class="core-dropdown__button ml-auto" src="./assets/icons/more.svg" alt="">' +
                                '<ul class="core-dropdown__menu">' +
                                    '<li><a href="#">Reply</a></li>' +
                                    '<li><a href="#">Delete</a></li>' +
                                '</ul>' +
                            '</div>' +
                            '<div class="message-item__text">' + messageText + '</div>' +
                        '</div>' +
                        '<div class="message-item__time">' + timeString + '</div>' +
                    '</div>';

                // Append message to chat body
                $messageBody.append(messageHtml);

                // Clear input
                $messageInput.val('');

                // Scroll to bottom
                $messageBody.scrollTop($messageBody[0].scrollHeight);
            }
        });
    </script>
