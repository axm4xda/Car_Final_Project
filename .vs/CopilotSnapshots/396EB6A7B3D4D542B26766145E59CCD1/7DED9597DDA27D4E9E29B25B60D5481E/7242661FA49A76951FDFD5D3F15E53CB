	<script>
		// ====== Role Selector ======
		(function () {
			var userRadio  = document.getElementById('role-user');
			var agentRadio = document.getElementById('role-agent');
			var userBox    = document.getElementById('role-user-box');
			var agentBox   = document.getElementById('role-agent-box');

			if (!userRadio || !agentRadio) return;

			var activeStyle   = 'border:2px solid #FF5722;border-radius:10px;padding:12px 16px;text-align:center;background:#fff5f2;transition:border-color 0.2s,background 0.2s;';
			var inactiveStyle = 'border:2px solid #e5e7eb;border-radius:10px;padding:12px 16px;text-align:center;transition:border-color 0.2s,background 0.2s;';

			function updateStyles() {
				if (userRadio.checked) {
					userBox.setAttribute('style',  activeStyle);
					agentBox.setAttribute('style', inactiveStyle);
				} else {
					agentBox.setAttribute('style', activeStyle);
					userBox.setAttribute('style',  inactiveStyle);
				}
			}

			updateStyles();
			userRadio.addEventListener('change',  updateStyles);
			agentRadio.addEventListener('change', updateStyles);

			// Bütün label-ə klik işlənsin
			document.querySelectorAll('.role-selector').forEach(function(label) {
				label.addEventListener('click', function () {
					setTimeout(updateStyles, 0);
				});
			});
		})();

		// ====== AJAX Register Form ======
		$('#registerForm').on('submit', function(e) {
			e.preventDefault();

			var form = $(this);
			var url = form.attr('action');

			// Forma daxil edilmiş bütün məlumatları toplayır
			var formData = {
				Email: form.find('input[name="Email"]').val(),
				Password: form.find('input[name="Password"]').val(),
				ConfirmPassword: form.find('input[name="ConfirmPassword"]').val(),
				Role: form.find('input[name="Role"]:checked').val(),
				returnUrl: form.find('input[name="returnUrl"]').val()
			};

			// AJAX POST sorğusu göndərir
			$.ajax({
				type: 'POST',
				url: url,
				data: formData,
				success: function(response) {
					// Uğurlu qeydiyyat sonrası istiqamətlənəcək URL müəyy